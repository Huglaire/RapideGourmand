<section class="menu-order-panel">

    <div class="card shadow-sm">

        <div class="card-body">

            <h2 class="h4 mb-4 text-center">
                Choisissez votre menu
            </h2>

            <div class="d-grid gap-3 mb-4">

                <button
                    type="button"
                    class="btn btn-outline-primary active"
                >
                    Entrée + plat + dessert

                    <br>

                    <small id="menu-price">
                        -
                    </small>

                </button>

            </div>

            <div class="mb-4">

                <label
                    for="guest-number"
                    class="form-label"
                >
                    Nombre de personnes
                </label>

                <input
                    id="guest-number"
                    type="number"
                    class="form-control"
                >

            </div>

            <div class="mb-4">

                <strong>
                    Prix estimé
                </strong>

                <p
                    id="menu-estimated-price"
                    class="fs-3 fw-bold text-primary mb-0"
                >
                    -
                </p>

            </div>

            <button
                id="order-button"
                class="btn btn-primary-custom w-100"
                type="button"
            >
                Aller à la commande
            </button>

        </div>

    </div>

</section>