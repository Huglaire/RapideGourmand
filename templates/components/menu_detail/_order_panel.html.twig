<section class="menu-order-panel">

	<div class="card shadow-sm">

		<div class="card-body">

			<h2 class="h4 mb-4 text-center">
				Votre commande
			</h2>

			{# Informations du menu sélectionné #}
			<div class="order-panel__menu mb-4">

				<h3 id="selected-menu-name" class="h5 mb-2">
					-
				</h3>

				<p id="selected-menu-price" class="text-muted mb-0">
					-
				</p>

			</div>

			<hr>

			{# Nombre de personnes #}
			<div class="mb-4">

				<label for="guest-number" class="form-label fw-semibold">
					Nombre de personnes
				</label>

				<input id="guest-number" type="number" class="form-control" min="1" step="1">

				<small id="minimum-guests" class="text-muted d-block">
					-
				</small>

				<small id="discount-threshold" class="text-success d-block mt-1">
					-
				</small>

			</div>

			<hr>

			{# Récapitulatif du prix #}
			<div class="order-summary">

				<div class="summary-row">
					<span>Prix unitaire</span>
					<span id="unit-price">-</span>
				</div>

				<div class="summary-row">
					<span>Personnes</span>
					<span id="summary-guests">-</span>
				</div>

				<div class="summary-row">
					<span>Sous-total</span>
					<span id="subtotal">-</span>
				</div>

				<div class="summary-row">
					<span id="discount-label">Remise</span>
					<span id="discount">-</span>
				</div>

				<div class="summary-row">
					<span>Livraison</span>
					<span id="delivery">À calculer</span>
				</div>

				<hr>

				<div class="summary-row summary-total">
					<span>TOTAL</span>
					<span id="total">-</span>
				</div>

			</div>

			<button id="order-button" class="btn btn-primary-custom w-100 mt-4" type="button">
				Aller à la commande
			</button>

		</div>

	</div>

</section>
