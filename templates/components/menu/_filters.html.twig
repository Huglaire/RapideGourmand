<aside class="menu-filters">

    <h2>Filtres</h2>

    {# Sélection des thèmes #}
    <section class="filter-group">

        <h3>Thèmes</h3>

        {% for theme in themes %}

            <label>

                <input
                    type="checkbox"
                    name="themes[]"
                    value="{{ theme.id }}"
                    {% if theme.id in filters.themes|default([]) %}
                        checked
                    {% endif %}
                >

                {{ theme.title }}

            </label>

        {% endfor %}

    </section>

    {# Filtre sur le nombre minimum de personnes #}
    <section class="filter-group">

        <h3>Nombre de personnes minimum</h3>

        <div class="range-filter">

            <output class="range-output">
                {{ filters.guestNumber|default(guestNumberRange.min) }}
            </output>

            <input
                id="guest-number-range"
                type="range"
                name="guestNumber"
                min="{{ guestNumberRange.min }}"
                max="{{ guestNumberRange.max }}"
                value="{{ filters.guestNumber|default(guestNumberRange.min) }}"
            >

            <div class="range-values">
                <span>{{ guestNumberRange.min }}</span>
                <span>{{ guestNumberRange.max }}</span>
            </div>

        </div>

    </section>

    {# Filtre sur le prix par personne #}
    <section class="filter-group">

        <h3>Prix par personne</h3>

        <div class="range-filter">

            <output class="range-output">
                {{ filters.price|default(priceRange.min) }} €
            </output>

            <input
                id="price-range"
                type="range"
                name="price"
                min="{{ priceRange.min }}"
                max="{{ priceRange.max }}"
                value="{{ filters.price|default(priceRange.min) }}"
                step="0.01"
            >

            <div class="range-values">
                <span>{{ priceRange.min }} €</span>
                <span>{{ priceRange.max }} €</span>
            </div>

        </div>

    </section>

    {# Sélection des régimes alimentaires #}
    <section class="filter-group">

        <h3>Régimes alimentaires</h3>

        {% for diet in diets %}

            <label>

                <input
                    type="checkbox"
                    name="diets[]"
                    value="{{ diet.id }}"
                    {% if diet.id in filters.diets|default([]) %}
                        checked
                    {% endif %}
                >

                {{ diet.title }}

            </label>

        {% endfor %}

    </section>

    <button
        type="submit"
        class="btn btn-primary w-100"
    >
        Appliquer
    </button>

</aside>