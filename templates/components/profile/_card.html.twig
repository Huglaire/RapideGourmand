<div class="profile-card">

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="profile-card-header">

                <h2 class="h4 mb-0">
                    Mes informations
                </h2>

                <button id="edit-profile-button" type="button" class="btn btn-primary-custom">
                    Modifier
                </button>

            </div>


            <div id="profile-message"></div>


            <div id="profile-view">

                <p>
                    <strong>Prénom :</strong>
                    <span id="profile-first-name"></span>
                </p>

                <p>
                    <strong>Nom :</strong>
                    <span id="profile-last-name"></span>
                </p>

                <p>
                    <strong>Email :</strong>
                    <span id="profile-email"></span>
                </p>

                <p>
                    <strong>Téléphone :</strong>
                    <span id="profile-phone"></span>
                </p>

                <p>
                    <strong>Adresse :</strong>
                    <span id="profile-street"></span>
                </p>

                <p>
                    <strong>Code postal :</strong>
                    <span id="profile-postal-code"></span>
                </p>

                <p>
                    <strong>Ville :</strong>
                    <span id="profile-city"></span>
                </p>

            </div>


            <div class="mt-4 d-flex flex-wrap gap-2">

                <a href="{{ path('order_history') }}" class="btn btn-primary-custom">
                    Mes commandes
                </a>


                <button
                    id="delete-account-button"
                    type="button"
                    class="btn btn-outline-danger d-none"
                >
                    Désactiver mon profil
                </button>

            </div>


            <hr class="my-4">


            <div class="review-section">

                <h3 class="h5 mb-3">
                    Laisser un avis
                </h3>


                <div id="review-message"></div>


                <div id="review-already-sent" class="alert alert-info d-none">

                    Vous avez déjà publié un avis. Merci pour votre retour !

                </div>


                <form id="review-form">

                    <div class="mb-3">

                        <label for="review-rating" class="form-label">
                            Note
                        </label>


                        <select id="review-rating" class="form-select" required>

                            <option value="">
                                Choisir une note
                            </option>

                            <option value="5">
                                5 / 5
                            </option>

                            <option value="4">
                                4 / 5
                            </option>

                            <option value="3">
                                3 / 5
                            </option>

                            <option value="2">
                                2 / 5
                            </option>

                            <option value="1">
                                1 / 5
                            </option>

                        </select>

                    </div>


                    <div class="mb-4">

                        <label for="review-comment" class="form-label">
                            Commentaire
                        </label>


                        <textarea
                            id="review-comment"
                            class="form-control"
                            rows="5"
                            maxlength="1000"
                            placeholder="Partagez votre expérience avec Rapide & Gourmand..."
                            required
                        ></textarea>

                    </div>


                    <button type="submit" class="btn btn-primary-custom">
                        Envoyer mon avis
                    </button>


                </form>


            </div>


            <div id="profile-edit" class="d-none">


                <form id="profile-form">


                    <div class="row">


                        <div class="col-md-6 mb-3">


                            <label for="firstName" class="form-label">
                                Prénom
                            </label>


                            <input type="text" id="firstName" class="form-control">


                        </div>


                        <div class="col-md-6 mb-3">


                            <label for="lastName" class="form-label">
                                Nom
                            </label>


                            <input type="text" id="lastName" class="form-control">


                        </div>


                        <div class="col-12 mb-3">


                            <label for="email" class="form-label">
                                Email
                            </label>


                            <input type="email" id="email" class="form-control">


                        </div>


                        <div class="col-md-6 mb-3">


                            <label for="phone" class="form-label">
                                Téléphone
                            </label>


                            <input type="text" id="phone" class="form-control">


                        </div>


                        <div class="col-md-6 mb-3">


                            <label for="postalCode" class="form-label">
                                Code postal
                            </label>


                            <input type="text" id="postalCode" class="form-control">


                        </div>


                        <div class="col-12 mb-3">


                            <label for="street" class="form-label">
                                Adresse
                            </label>


                            <input type="text" id="street" class="form-control">


                        </div>


                        <div class="col-12 mb-4">


                            <label for="city" class="form-label">
                                Ville
                            </label>


                            <input type="text" id="city" class="form-control">


                        </div>


                    </div>


                    <div class="profile-form-actions">


                        <button type="submit" class="btn btn-primary-custom">
                            Enregistrer
                        </button>


                        <button
                            type="button"
                            id="cancel-profile-edit"
                            class="btn btn-outline-secondary"
                        >
                            Annuler
                        </button>


                    </div>


                </form>


            </div>


        </div>

    </div>

</div>