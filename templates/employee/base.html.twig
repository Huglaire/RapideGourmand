{% extends 'base.html.twig' %}

{% block title %}
    {% block employee_title %}Espace Employé{% endblock %} | Rapide & Gourmand
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row min-vh-100">

        <aside class="col-md-3 col-lg-2 bg-dark p-0">
            {% include 'employee/components/_sidebar.html.twig' %}
        </aside>

        <main class="col-md-9 col-lg-10 bg-light">

            <div class="container py-4">

                <h1 class="mb-4">
                    {% block page_title %}{% endblock %}
                </h1>

                {% block employee_content %}{% endblock %}

            </div>

        </main>

    </div>
</div>
{% endblock %}