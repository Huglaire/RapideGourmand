{% extends 'base.html.twig' %}

{% block title %}
    {{ title }} | Rapide & Gourmand
{% endblock %}

{% block body %}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="fw-bold mb-0">
            {{ title }}
        </h1>

        <a href="{{ path('employee_reviews') }}" class="btn btn-outline-secondary">
            Retour
        </a>

    </div>

    {% if reviews is empty %}

        <div class="alert alert-info">
            Aucun avis à afficher.
        </div>

    {% else %}

        <div class="row g-4">

            {% for review in reviews %}

                <div class="col-lg-6">

                    <div class="card shadow-sm h-100">

                        <div class="card-body">

                            <div class="d-flex justify-content-between mb-3">

                                <strong>
                                    {{ review.user.firstName }}
                                    {{ review.user.lastName }}
                                </strong>

                                <span class="badge bg-danger">
                                    {{ review.rating }}/5
                                </span>

                            </div>

                            <p class="mb-3">
                                {{ review.comment }}
                            </p>

                            <small class="text-muted d-block mb-3">
                                {{ review.createdAt|date('d/m/Y à H:i') }}
                            </small>

                            {% if title == 'Avis à modérer' %}

                                <div class="d-flex gap-2">

                                    <button
                                        class="btn btn-success flex-fill review-approve"
                                        data-review-id="{{ review.id }}"
                                    >
                                        Valider
                                    </button>

                                    <button
                                        class="btn btn-danger flex-fill review-reject"
                                        data-review-id="{{ review.id }}"
                                    >
                                        Refuser
                                    </button>

                                </div>

                            {% endif %}

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% endif %}

</div>

{% endblock %}