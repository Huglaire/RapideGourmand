{% extends 'base.html.twig' %}

{% block title %}Gestion des avis | Rapide & Gourmand{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="mb-5 text-center">
        <h1 class="fw-bold">Gestion des avis</h1>

        <p class="text-muted mb-0">
            Sélectionnez une action.
        </p>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-6 col-lg-4">
            <a href="#" class="text-decoration-none">

                <div class="card h-100 shadow-sm">

                    <div class="card-body text-center">

                        <i class="bi bi-hourglass-split display-4 text-danger mb-3"></i>

                        <h3 class="h5">
                            Avis à modérer
                        </h3>

                        <p class="text-muted mb-0">
                            Consulter les avis en attente de validation.
                        </p>

                    </div>

                </div>

            </a>
        </div>

        <div class="col-md-6 col-lg-4">
            <a href="#" class="text-decoration-none">

                <div class="card h-100 shadow-sm">

                    <div class="card-body text-center">

                        <i class="bi bi-check-circle display-4 text-danger mb-3"></i>

                        <h3 class="h5">
                            Avis validés
                        </h3>

                        <p class="text-muted mb-0">
                            Consulter les avis publiés.
                        </p>

                    </div>

                </div>

            </a>
        </div>

        <div class="col-md-6 col-lg-4">
            <a href="#" class="text-decoration-none">

                <div class="card h-100 shadow-sm">

                    <div class="card-body text-center">

                        <i class="bi bi-x-circle display-4 text-danger mb-3"></i>

                        <h3 class="h5">
                            Avis refusés
                        </h3>

                        <p class="text-muted mb-0">
                            Consulter les avis refusés.
                        </p>

                    </div>

                </div>

            </a>
        </div>

    </div>

</div>
{% endblock %}