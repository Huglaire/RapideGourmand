{% extends 'base.html.twig' %}

{% block title %}Gestion des commandes | Rapide & Gourmand
{% endblock %}

{% block body %}
	<div class="container py-5">

		<div class="mb-5 text-center">
			<h1 class="fw-bold">Gestion des commandes</h1>
			<p class="text-muted mb-0">
				Sélectionnez une action.
			</p>
		</div>

		<div class="row g-4 justify-content-center">

			<div class="col-md-6 col-lg-4">
				<a href="#" class="text-decoration-none">

					<div class="card h-100 shadow-sm">

						<div class="card-body text-center">

							<i class="bi bi-hourglass-split display-4 text-danger mb-3"></i>

							<h3 class="h5">
								Commandes en attente
							</h3>

							<p class="text-muted mb-0">
								Consulter les commandes à traiter.
							</p>

						</div>

					</div>

				</a>
			</div>

			<div class="col-md-6 col-lg-4">
				<a href="{{ path('employee_orders_list') }}" class="text-decoration-none">

					<div class="card h-100 shadow-sm">

						<div class="card-body text-center">

							<i class="bi bi-clock-history display-4 text-danger mb-3"></i>

							<h3 class="h5">
								Historique des commandes
							</h3>

							<p class="text-muted mb-0">
								Consulter toutes les commandes.
							</p>

						</div>

					</div>

				</a>
			</div>

			<div class="col-md-6 col-lg-4">
				<a href="#" class="text-decoration-none">

					<div class="card h-100 shadow-sm">

						<div class="card-body text-center">

							<i class="bi bi-x-octagon display-4 text-danger mb-3"></i>

							<h3 class="h5">
								Commandes annulées
							</h3>

							<p class="text-muted mb-0">
								Consulter les commandes annulées.
							</p>

						</div>

					</div>

				</a>
			</div>

		</div>

	</div>
{% endblock %}
