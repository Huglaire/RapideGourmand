{% extends 'base.html.twig' %}

{% block title %}Espace Employé | Rapide & Gourmand
{% endblock %}

{% block body %}
	<div class="container py-5">

		<div class="text-center mb-5">
			<h1 class="fw-bold">Espace Employé</h1>
			<p class="text-muted mb-0">
				Sélectionnez une rubrique à administrer.
			</p>
		</div>

		<div class="row g-4 justify-content-center">

			<div class="col-md-6 col-lg-4">
				<div class="card h-100 shadow-sm">

					<div class="card-body text-center d-flex flex-column">

						<i class="bi bi-box-seam display-4 text-danger mb-3"></i>

						<h3 class="h5">Commandes</h3>

						<p class="text-muted flex-grow-1">
							Gérer les commandes des clients.
						</p>

						<a href="{{ path('employee_orders') }}" class="btn btn-danger">
							Accéder
						</a>

					</div>

				</div>
			</div>

			<div class="col-md-6 col-lg-4">
				<div class="card h-100 shadow-sm">

					<div class="card-body text-center d-flex flex-column">

						<i class="bi bi-journal-text display-4 text-danger mb-3"></i>

						<h3 class="h5">Menus</h3>

						<p class="text-muted flex-grow-1">
							Créer, modifier ou supprimer les menus.
						</p>

						<a href="{{ path('employee_menus') }}" class="btn btn-danger">
							Accéder
						</a>

					</div>

				</div>
			</div>

			<div class="col-md-6 col-lg-4">
				<div class="card h-100 shadow-sm">

					<div class="card-body text-center d-flex flex-column">

						<i class="bi bi-egg-fried display-4 text-danger mb-3"></i>

						<h3 class="h5">Plats</h3>

						<p class="text-muted flex-grow-1">
							Créer, modifier ou supprimer les plats.
						</p>

						<a href="{{ path('employee_dishes') }}" class="btn btn-danger">
							Accéder
						</a>

					</div>

				</div>
			</div>

			<div class="col-md-6 col-lg-4">
				<div class="card h-100 shadow-sm">

					<div class="card-body text-center d-flex flex-column">

						<i class="bi bi-chat-square-text display-4 text-danger mb-3"></i>

						<h3 class="h5">Avis</h3>

						<p class="text-muted flex-grow-1">
							Modérer les avis des clients.
						</p>

						<a href="{{ path('employee_reviews') }}" class="btn btn-danger">
							Accéder
						</a>

					</div>

				</div>
			</div>

			<div id="admin-card" class="col-md-6 col-lg-4 d-none">
				<div class="card h-100 shadow-sm">

					<div class="card-body text-center d-flex flex-column">

						<i class="bi bi-shield-lock display-4 text-danger mb-3"></i>

						<h3 class="h5">Administration</h3>

						<p class="text-muted flex-grow-1">
							Accéder aux fonctionnalités d'administration.
						</p>

						<a href="{{ path('front_admin_dashboard') }}" class="btn btn-danger">
							Accéder
						</a>

					</div>

				</div>
			</div>

		</div>

	</div>
{% endblock %}
