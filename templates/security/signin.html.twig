{% extends 'base.html.twig' %}

{% block title %}
    Connexion | Rapide & Gourmand
{% endblock %}

{% block body %}

<section class="signin">

    <div class="container">

        <div class="signin__card">

            <h1>Connexion</h1>

            <p>
                Connectez-vous pour accéder à votre espace personnel.
            </p>

            <form
                id="signin-form"
                data-turbo="false"
            >

                <div class="mb-3">

                    <label
                        for="email"
                        class="form-label"
                    >
                        Adresse e-mail
                    </label>

                    <input
                        id="email"
                        name="email"
                        type="email"
                        class="form-control"
                        required
                    >

                </div>

                <div class="mb-4">

                    <label
                        for="password"
                        class="form-label"
                    >
                        Mot de passe
                    </label>

                    <input
                        id="password"
                        name="password"
                        type="password"
                        class="form-control"
                        required
                    >

                </div>

                <div
                    id="signin-error"
                    class="alert alert-danger d-none"
                ></div>

                <button
                    type="submit"
                    class="btn btn-primary w-100"
                >
                    Se connecter
                </button>

            </form>

        </div>

    </div>

</section>

{% endblock %}