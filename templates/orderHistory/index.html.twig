{% extends 'base.html.twig' %}

{% block title %}
	Mes commandes | Rapide & Gourmand
{% endblock %}

{% block body %}

	<section class="py-5">

		<div class="container">

			<div class="row mb-5">

				<div class="col">

					<h1>
						Mes commandes
					</h1>

					<p class="lead mb-0">
						Retrouvez ici l'ensemble de vos commandes et leur état.
					</p>

				</div>

			</div>

			<div id="orders-container" class="row g-4"></div>

		</div>

	</section>

	<template id="order-card-template">

		<div class="col-lg-6">

			<div class="card shadow-sm h-100">

				<div class="card-body">

					<div class="d-flex justify-content-between align-items-start mb-3">

						<h2 class="h5 mb-0 order-title"></h2>

						<span class="badge order-status"></span>

					</div>

					<div class="mb-2">

						<strong>
							Livraison :
						</strong>

						<span class="order-date"></span>

						<div class="mb-2">

							<strong>
								Adresse :
							</strong>

							<span class="order-address"></span>

						</div>

					</div>

					<div class="mb-2">

						<strong>
							Commandée le :
						</strong>

						<span class="order-created-at"></span>

					</div>

					<div class="mb-2">

						<strong>
							Nombre de personnes :
						</strong>

						<span class="order-guests"></span>

					</div>

					<div class="mb-2">

						<strong>
							Montant :
						</strong>

						<span class="order-total"></span>

					</div>

					<div class="mt-4">

						<button class="btn btn-outline-danger cancel-order">
							Annuler la commande
						</button>

					</div>

				</div>

			</div>

		</div>

	</template>

{% endblock %}
