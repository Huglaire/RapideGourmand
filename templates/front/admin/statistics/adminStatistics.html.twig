{% extends 'base.html.twig' %}

{% block title %}Statistiques{% endblock %}

{% block body %}

<div class="container py-5">

    <h1 class="mb-4">Statistiques</h1>

    <div class="row g-4 mb-5">

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Nombre total de commandes</h5>
                    <p
                        id="total-orders"
                        class="display-5 mb-0"
                    >
                        —
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Menu le plus commandé</h5>
                    <p
                        id="best-menu"
                        class="display-6 mb-0"
                    >
                        —
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm mb-5">

        <div class="card-header">
            Nombre de commandes par menu
        </div>

        <div class="card-body">

            <canvas id="orders-chart"></canvas>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-header">
            Chiffre d'affaires
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-4">

                    <label
                        for="menu-select"
                        class="form-label"
                    >
                        Menu
                    </label>

                    <select
                        id="menu-select"
                        class="form-select"
                    >
                        <option value="">
                            Tous les menus
                        </option>
                    </select>

                </div>

                <div class="col-md-3">

                    <label
                        for="start-date"
                        class="form-label"
                    >
                        Date de début
                    </label>

                    <input
                        id="start-date"
                        type="date"
                        class="form-control"
                    >

                </div>

                <div class="col-md-3">

                    <label
                        for="end-date"
                        class="form-label"
                    >
                        Date de fin
                    </label>

                    <input
                        id="end-date"
                        type="date"
                        class="form-control"
                    >

                </div>

                <div class="col-md-2 d-flex align-items-end">

                    <button
                        id="revenue-button"
                        class="btn btn-primary w-100"
                    >
                        Filtrer
                    </button>

                </div>

            </div>

            <hr>

            <h3 id="revenue-result">

                Chiffre d'affaires :
                —

            </h3>

        </div>

    </div>

</div>

{% endblock %}