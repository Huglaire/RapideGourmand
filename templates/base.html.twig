<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">

    {# Permet un affichage responsive sur mobile #}
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# Chaque page pourra définir son propre titre #}
    <title>{% block title %}Rapide & Gourmand{% endblock %}</title>

    {# Favicon du site (à ajouter plus tard dans le dossier public/) #}
    <link rel="icon" href="{{ asset('favicon.ico') }}">

    {% block stylesheets %}
        {# Chargement de Bootstrap pour toute l'application #}
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        >
        
    {% endblock %}

    {% block javascripts %}
        {# Charge automatiquement les fichiers JavaScript déclarés avec Importmap #}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}
    {% endblock %}

    {# Hot Reload utilisé uniquement en développement avec FrankenPHP #}
    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>

<body>

    {# Barre de navigation commune à toutes les pages #}
    {% include 'partials/_navbar.html.twig' %}

    {# Contenu propre à chaque page #}
    <main>
        {% block body %}{% endblock %}
    </main>

    {# Pied de page commun à toute l'application #}
    {% include 'partials/_footer.html.twig' %}

    {# JavaScript de Bootstrap (menus, modales, etc.) #}
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"
    ></script>

</body>
</html>